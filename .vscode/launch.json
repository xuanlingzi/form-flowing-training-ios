{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug on iPhone 17 Simulator",
            "type": "lldb",
            "request": "custom",
            "preLaunchTask": "Deploy to Simulator",
            "targetCreateCommands": [
                "target create \"${workspaceFolder}/.build/DerivedData/Build/Products/Debug-iphonesimulator/FormFlowing.app/FormFlowing\""
            ],
            "processCreateCommands": [
                "process attach --name FormFlowing",
                "continue"
            ],
            "sourceLanguages": [
                "swift",
                "objective-c"
            ]
        }
    ]
}