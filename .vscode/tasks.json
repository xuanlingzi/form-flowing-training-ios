{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate Project",
            "type": "shell",
            "command": "xcodegen",
            "args": [
                "generate"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "使用 XcodeGen 从 project.yml 生成 .xcodeproj 文件"
        },
        {
            "label": "Build for Simulator",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "FormFlowing.xcodeproj",
                "-scheme",
                "FormFlowing",
                "-destination",
                "platform=iOS Simulator,name=iPhone 17",
                "-derivedDataPath",
                ".build/DerivedData",
                "build"
            ],
            "dependsOn": [
                "Generate Project"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "编译项目至模拟器 (iPhone 17)"
        },
        {
            "label": "Deploy to Simulator",
            "type": "shell",
            "command": "xcrun simctl boot 'iPhone 17' 2>/dev/null || true; open -a Simulator; xcrun simctl terminate 'iPhone 17' com.formflowing.app 2>/dev/null || true; xcrun simctl install 'iPhone 17' .build/DerivedData/Build/Products/Debug-iphonesimulator/FormFlowing.app && xcrun simctl launch --wait-for-debugger 'iPhone 17' com.formflowing.app",
            "dependsOn": [
                "Build for Simulator"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "部署并以调试模式启动 App（等待调试器附加）"
        },
        {
            "label": "Run on Simulator",
            "type": "shell",
            "command": "xcrun simctl boot 'iPhone 17' 2>/dev/null || true; open -a Simulator; xcrun simctl terminate 'iPhone 17' com.formflowing.app 2>/dev/null || true; xcrun simctl install 'iPhone 17' .build/DerivedData/Build/Products/Debug-iphonesimulator/FormFlowing.app && xcrun simctl launch 'iPhone 17' com.formflowing.app",
            "dependsOn": [
                "Build for Simulator"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "部署并直接运行 App（无调试器）"
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "rm -rf .build/DerivedData && xcodebuild clean",
            "group": "build",
            "detail": "清理构建缓存"
        }
    ]
}